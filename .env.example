PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgres://router:router@localhost:5432/router
TEST_DATABASE_URL=postgres://router:router@localhost:5432/router_test
CREATE_DATABASE_BEFORE_MIGRATE=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-argon2-password-hash

# Development example only. Production must set a strong unique secret with at least 32 characters.
CHANNEL_KEY_ENCRYPTION_SECRET=replace-with-at-least-32-characters-secret

# Production default is false. Set true only for explicit private-network upstream deployments.
ALLOW_PRIVATE_UPSTREAM_BASE_URLS=false

# Total deadline for OpenAI-compatible channel tests, covering DNS, connect, and response handling.
CHANNEL_TEST_TIMEOUT_MS=5000
